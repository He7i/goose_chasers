{
  "name": "easter-hunt-app",
  "version": "2.0.0",
  "description": "Easter Hunt App - React Frontend + Node.js/Express Backend",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "docker:build": "docker build -t easter-hunt-app .",
    "docker:run": "docker run -p 5000:5000 -e DATABASE_URL=mysql://user:pass@host/db easter-hunt-app"
  },
  "keywords": ["easter", "hunt", "game", "react", "express"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "mysql2": "^3.2.0",
    "multer": "^1.4.5-lts.1",
    "express-session": "^1.17.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "axios": "^1.3.4"
  },
  "devDependencies": {
    "concurrently": "^7.6.0",
    "nodemon": "^2.0.20"
  }
}
